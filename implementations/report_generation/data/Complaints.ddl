CREATE TABLE IF NOT EXISTS "complaints" (
        "id" INTEGER,
        "product_type" TEXT,
        "narrative" TEXT,
        "product_type_specific" TEXT,
        "date_received" TEXT,
        "sub_product" TEXT,
        "issue" TEXT,
        "sub_issue" TEXT,
        "company" TEXT,
        "state" TEXT,
        "timely_response" TEXT
);
